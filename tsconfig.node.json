{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2023"],
    "types": ["node"],
    // Rozszerzenia `.ts` w importach względnych — pozwalają uruchomić transporty sieciowe
    // wprost pod `node --experimental-transform-types` w testach (Node wymaga jawnego
    // rozszerzenia). Flaga tylko dopuszcza tę formę, nie wymusza jej; esbuild/electron-vite
    // rozwiązuje `.ts` przy budowaniu. Wymaga noEmit (spełnione).
    "allowImportingTsExtensions": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    // TypeScript 7 usunął "baseUrl" — ścieżki muszą być względne.
    "paths": {
      "@core/*": ["./src/core/*"],
      "@shared/*": ["./src/shared/*"],
      "@services/*": ["./src/services/*"]
    }
  },
  "include": [
    "electron.vite.config.ts",
    "src/main/**/*",
    "src/preload/**/*",
    "src/services/**/*",
    "src/core/**/*",
    "src/shared/**/*"
  ]
}
