{
  "name": "lumashell",
  "version": "0.9.0",
  "description": "Szybki, konfigurowalny terminal dla Windows oparty na Electronie",
  "main": "./out/main/index.js",
  "author": "xdziuba",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "electron-vite build",
    "dist": "npm run build && electron-builder",
    "dist:dir": "npm run build && electron-builder --dir",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test:unit": "node --experimental-transform-types --no-warnings tests/unit/pane-tree.test.ts",
    "test:integration": "node --experimental-transform-types --no-warnings tests/integration/ssh-transport.test.ts",
    "test:known-hosts": "node --experimental-transform-types --no-warnings tests/integration/known-hosts.test.ts",
    "test:serial": "node --experimental-transform-types --no-warnings tests/integration/serial-transport.test.ts",
    "test:net": "node --experimental-transform-types --no-warnings tests/integration/net-transport.test.ts",
    "test:net-validation": "node --experimental-transform-types --no-warnings tests/unit/network-validation.test.ts",
    "test:perf": "node tests/performance/pty-throughput.mjs"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "node-pty": "^1.1.0",
    "serialport": "^13.0.0",
    "ssh2": "^1.17.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ssh2": "^1.15.5",
    "@vitejs/plugin-react": "^5.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "electron": "^43.1.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sass": "^1.101.0",
    "typescript": "^7.0.2",
    "vite": "^7.3.6",
    "zustand": "^5.0.14"
  }
}
