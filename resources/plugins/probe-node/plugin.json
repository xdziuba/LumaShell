{
  "id": "com.lumashell.probe-node",
  "name": "Sonda Node",
  "version": "1.1.0",
  "apiVersion": "2",
  "runtime": "node",
  "main": "dist/index.js",
  "description": "Wtyczka diagnostyczna: sprawdza, co widzi kod działający we własnym procesie wtyczki. Nic nie zmienia i nic nie wysyła — tylko zapisuje wynik do swojego logu.",
  "permissions": [
    "commands.register",
    "notifications.show",
    "terminal.read",
    "terminal.write"
  ],
  "contributes": {
    "commands": [
      {
        "id": "probe.terminals",
        "title": "Sonda: pokaż sesje terminala"
      },
      {
        "id": "probe.read",
        "title": "Sonda: przeczytaj wyjście aktywnej sesji"
      }
    ]
  }
}
